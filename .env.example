# Copy to .env and fill in values (never commit .env)

# --- Bullhorse (Telegram) ---
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Optional: Chat ID of the administrator to receive escalation notifications.
# TELEGRAM_ADMIN_CHAT_ID=

# --- GitHub ---
# Classic PAT or fine-grained token with repo access (Contents + Metadata read at minimum).
GITHUB_TOKEN=

# When the user writes `--repo recipe-rn` without `owner/`, this org or user is used → owner/recipe-rn
GITHUB_DEFAULT_OWNER=

# GitHub webhook secret for signature verification (optional but recommended)
GITHUB_WEBHOOK_SECRET=

# Key used to encrypt GitHub tokens stored in thread metadata
# GITHUB_TOKEN_ENCRYPTION_KEY=

# --- HTTP Server (Webapp + Webhooks) ---
# Port for the web server (agent API + webhooks)
PORT=7860

# Public URL for webhooks (needed for Telegram/GitHub to send webhooks)
# Example: https://your-domain.com or use ngrok for local development
WEBHOOK_URL=https://your-domain.com

# --- LLM Provider ---
# Which provider to use: "openai" (default) or "google"
#   "openai"  — OpenAI-compatible (OpenAI, OpenRouter, Z.ai GLM, any compatible proxy)
#   "google"  — Native Google Gemini via @langchain/google-genai
# If not set, auto-detects: uses "google" when GOOGLE_API_KEY is set and OPENAI_API_KEY is absent.
# LLM_PROVIDER=openai

# --- Google Gemini (native, requires LLM_PROVIDER=google) ---
# GOOGLE_API_KEY=your_google_api_key
# MODEL=gemini-2.5-flash-preview-04-17

# --- OpenAI-compatible (default) ---
# Root URL for the OpenAI-compatible API (include /v1 if your provider expects it).
# Examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   (your Z.ai / GLM OpenAI-compatible base URL from their docs)
OPENAI_BASE_URL=https://api.openai.com/v1

# API key for that same host (not necessarily an "OpenAI" key — whatever that base URL requires).
OPENAI_API_KEY=

# Model id on that provider, e.g. gpt-4o-mini, google/gemini-2.0-flash-001 (OpenRouter), or GLM model name from Z.ai.
MODEL=

# Optional fallback model/provider used when the primary one is rate limited.
# If any fallback var is set, OPENAI_API_KEY_FALLBACK and MODEL_FALLBACK are both required.
# OPENAI_BASE_URL_FALLBACK=https://api.openai.com/v1
# OPENAI_API_KEY_FALLBACK=
# MODEL_FALLBACK=

# Retry policy for transient provider errors.
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BASE_MS=750

# Optional: LangSmith tracing (https://smith.langchain.com/)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=

# --- Langfuse Observability (https://langfuse.com) ---
# Enable LLM tracing with Langfuse for observability, debugging, and analytics.
# Get your keys from: https://cloud.langfuse.com or self-hosted instance.
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# Optional: Langfuse host (for self-hosted or EU region)
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Pipeline (coder → format → linter → validate → tests) ---
# Directory the linter runs in (default: current working directory).
# WORKSPACE_ROOT=/path/to/checkout

# Shell command for the post-coder linter step (default: TypeScript check).
# LINTER_COMMAND=bunx tsc --noEmit

# Optional thread metadata persistence settings.
# THREAD_METADATA_PATH=.cursor/state/thread-metadata.json
# THREAD_METADATA_TTL_MS=604800000

# --- Compaction Middleware (Context Management) ---
# Compaction cascade trigger (default: 0.7 = 70% of context)
# When to run ANY compaction (levels 1-3: COLLAPSE, TRUNCATE, MICROCOMPACT)
COMPACTION_CASCADE_TRIGGER_FRACTION=0.7

# Compaction summarize trigger (default: 0.85 = 85% of context)
# When to use expensive LLM summarization (level 4)
COMPACTION_TRIGGER_FRACTION=0.85

# How many messages to keep after compaction (default: 10)
COMPACTION_KEEP_MESSAGES=10

# Maximum consecutive compaction failures before circuit breaker (default: 3)
COMPACTION_MAX_FAILURES=3

# Enable/disable microcompaction (clearing stale tool results)
COMPACTION_MICROCOMPACT=true

# Minutes of gap before clearing tool results (default: 60)
COMPACTION_MICROCOMPACT_GAP_MINUTES=60

# Enable/disable post-compaction file restoration
COMPACTION_RESTORATION=true

# How many recent files to restore after compaction (default: 5)
COMPACTION_RESTORATION_MAX_FILES=5

# --- Supabase (Repo Memory) ---
# When enabled, Bullhorse persists per-repo “memories” after each agent turn.
# Requires the SQL schema in `supabase/migrations/*_repo_memory.sql`.
SUPABASE_REPO_MEMORY_ENABLED=false
SUPABASE_URL=
# Use the service role key for server-side writes (never expose to clients).
SUPABASE_SERVICE_ROLE_KEY=
# Optional: also write `repo_memory_chunks` rows (no embeddings generated by default).
SUPABASE_REPO_MEMORY_VECTOR_CHUNKS=false

# --- Extended Mode (optional: includes planner and fixer nodes) ---
# When set to true, the pipeline includes additional agentic nodes:
# - planner: Analyzes the task and creates a plan before coding
# - fixer: Attempts to fix test/validation failures after deterministic checks
# Standard mode: coder → format → linter → validate → tests → END
# Extended mode: planner → coder → format → linter → validate → tests → fixer → END
EXTENDED_MODE=false

# --- Agent Provider (harness backend) ---
# Which agent backend to use: "opencode" (default) or "deepagents".
AGENT_PROVIDER=opencode

# DeepAgents only: stream graph steps + LLM tokens to stderr for local debugging.
# Default follows stderr TTY (on for `bun run start`, usually off in Docker). Telegram/GitHub replies stay final-only.
# AGENT_TRACE_STDERR=true
# AGENT_TRACE_STDERR=false

# DeepAgents only: maximum number of agent steps before recursion limit error (default: 2000).
# For complex SWE tasks requiring many iterations, you may need to increase this.
# AGENT_RECURSION_LIMIT=2000

# --- OpenCode (optional overrides) ---
# Host/port for the embedded OpenCode server started by the SDK.
OPENCODE_HOSTNAME=127.0.0.1
OPENCODE_PORT=4096
# How long (ms) the SDK waits for the OpenCode server to start.
OPENCODE_START_TIMEOUT_MS=10000

# --- DeepAgents (optional fallback provider) ---
# DeepAgents server host (used if you set AGENT_PROVIDER=deepagents).
DEEPAGENTS_HOST=127.0.0.1
# DeepAgents server port.
DEEPAGENTS_PORT=4096
# How long (ms) the SDK waits for the DeepAgents server to start.
DEEPAGENTS_START_TIMEOUT_MS=5000
# Anthropic API key for Claude (only required for DeepAgents when using Anthropic models)
# ANTHROPIC_API_KEY=

# --- Tool Invocation Limits ---
# Maximum number of times a tool can be invoked per thread (default: 10)
# TOOL_MAX_INVOCATIONS_DEFAULT=10
# Time window in milliseconds for detecting duplicate tool calls (default: 5000)
# TOOL_DEBOUNCE_WINDOW_MS=5000
# Custom per-tool limits as JSON string (default: none)
# Example: '{"grep": 5, "search_files": 3, "read_file": 15}'
# PER_TOOL_LIMITS_JSON={}

# --- Unified Sandbox Service ---
# Enable sandbox backend for isolated container execution
# When set to true, the agent will run in a sandbox container
USE_SANDBOX=false

# Sandbox provider: "opensandbox" or "daytona" (default: opensandbox)
SANDBOX_PROVIDER=opensandbox

# --- OpenSandbox (Alibaba) ---
# Get your API key from: https://opensandbox.io
OPENSANDBOX_DOMAIN=api.opensandbox.io
OPENSANDBOX_API_KEY=your-api-key-here

# OpenSandbox container configuration
OPENSANDBOX_IMAGE=ubuntu:22.04
OPENSANDBOX_TIMEOUT=1800
OPENSANDBOX_CPU=2
OPENSANDBOX_MEMORY=4Gi

# --- Daytona ---
# Get your API key from: https://daytona.io
DAYTONA_API_KEY=your-api-key-here

# Reuse existing sandbox by ID (optional)
# When set, the agent will reuse this sandbox instead of creating a new one
# The sandbox ID will be logged when a new sandbox is created
# DAYTONA_SANDBOX_ID=

# Daytona API configuration (optional)
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=us

# Daytona sandbox configuration
DAYTONA_IMAGE=oven/bun:1
DAYTONA_CPU=2
DAYTONA_MEMORY=4
DAYTONA_DISK=20
# DAYTONA_AUTOSTOP=0  # 0 = disabled, otherwise minutes of inactivity
# Optional pool behavior: auto-demote stale busy sandboxes to idle after N minutes
# (disabled when unset or <= 0)
# DAYTONA_POOL_STALE_BUSY_MINUTES=30

# --- Sandbox Snapshots (Daytona only) ---
# Enable snapshot-based sandbox initialization for faster startup
# When enabled, creates snapshots after first setup and reuses them for subsequent requests
SNAPSHOT_ENABLED=true

# Snapshot refresh interval in minutes (default: 30)
# Snapshots are refreshed periodically to keep dependencies up to date
SNAPSHOT_INTERVAL_MINUTES=30

# Maximum snapshot age in hours before refresh (default: 48)
# Snapshots older than this will be marked for refresh
SNAPSHOT_MAX_AGE_HOURS=48

# Storage directory for snapshot metadata (default: /tmp/snapshots)
SNAPSHOT_STORAGE_DIR=/tmp/snapshots

# Sandbox profile: "typescript", "javascript", "python", "java", or "polyglot"
# This determines which tools and dependencies are pre-installed in the sandbox
SANDBOX_PROFILE=typescript

# --- Subagent Configuration ---
# Enable/disable subagents (default: false)
SUBAGENTS_ENABLED=false

# Enable async subagents for parallel verification tasks (default: false)
ASYNC_SUBAGENTS_ENABLED=false

# Directory for repo-specific agents
# Path relative to workspace root where agent configuration files are stored
REPO_AGENTS_DIR=.agents/agents

# --- Per-subagent model configuration ---
# Model for exploration subagent (fast, cost-effective for quick analysis)
EXPLORE_AGENT_MODEL=haiku

# Model for planning subagent (uses main agent's model by default)
PLAN_AGENT_MODEL=inherit

# Model for general-purpose subagent tasks (uses main agent's model by default)
GENERAL_AGENT_MODEL=inherit

# Model for verification subagent (uses main agent's model by default)
VERIFICATION_AGENT_MODEL=inherit

# --- Async subagent settings ---
# Timeout for verification tasks in milliseconds (default: 300000 = 5 minutes)
VERIFICATION_TIMEOUT_MS=300000

# How often to poll async subagent status in milliseconds (default: 5000)
VERIFICATION_POLL_INTERVAL_MS=5000

# --- LangGraph worker pool for concurrent async tasks ---
# Number of parallel jobs per worker (default: 10)
# Higher values enable more concurrent verification tasks
LANGGRAPH_N_JOBS_PER_WORKER=10


# --- Memory System (Auto Memory for Agent Context) ---
# Enable persistent memory system for agent context across sessions
# When enabled, the agent remembers user preferences, project context, and feedback
MEMORY_ENABLED=false

# OpenAI embedding model for semantic search (default: text-embedding-3-small)
# Requires OPENAI_API_KEY to be set for embedding generation
MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# Similarity threshold for memory search (0.0-1.0, default: 0.75)
# Higher values = more strict matching, lower values = more results
MEMORY_SIMILARITY_THRESHOLD=0.75

# Maximum number of memories to retrieve per search (default: 5)
MEMORY_MAX_RESULTS=5

# Enable automatic memory consolidation (default: true)
# Consolidation merges duplicate memories and archives stale ones
MEMORY_CONSOLIDATION_ENABLED=true

# Consolidation interval in hours (default: 6)
# How often to run consolidation on active threads
MEMORY_CONSOLIDATION_INTERVAL_HOURS=6

# Minimum number of sessions before consolidation (default: 5)
# Consolidation only runs when this many sessions are active
MEMORY_CONSOLIDATION_MIN_SESSIONS=5

# Days after which memories are considered stale (default: 90)
# Stale memories are archived during consolidation
MEMORY_CONSOLIDATION_STALE_DAYS=90


